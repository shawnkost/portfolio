---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { socials } from '../data/socials';
import Headshot from '../images/me.png';
import HomeLayout from '../layouts/HomeLayout.astro';

const skills = await getCollection('skills');
const projects = await getCollection('projects');

const sortedSkills = skills.sort(
  (a, b) => (a.data.order || 0) - (b.data.order || 0)
);
---

<HomeLayout title="Shawn Kost - My Portfolio">
  <section>
    <div id="about" class="mb-6 w-full scroll-mt-20 px-6 md:scroll-mt-12">
      <div class="mx-auto flex max-w-7xl flex-wrap items-center md:flex-nowrap">
        <div class="mb-6 font-semibold
uppercase text-white md:w-3/4 lg:w-2/3">
          <h1 class="text-2xl md:text-4xl">Hi, my name is</h1>
          <h2 class="text-4xl md:text-7xl">Shawn Kost</h2>
          <h2 class="text-xl md:text-3xl">
            I am a
            <span class="text-primary">Software Engineer</span>
          </h2>
          <p class="mt-8 font-light normal-case text-white">
            Since a young age I have had a love for anything that involves
            computers and technology. I began with technical theater learning
            the ins and outs of stage production and lighting design. That
            passion has only grown with time which led to my first job as a
            computer technician, where I integrated computer systems and
            servers. Ultimately this led me to discovering the world of computer
            programming with an immense desire to pursue a career within it! I
            am excited to join a company that will not only challenge me, but
            help me grow into a better developer.
          </p>
        </div>
        <div>
          <Image
            src={Headshot}
            alt="myself"
            height={922}
            width={983}
            class="mb-6 w-full max-w-sm md:max-w-lg lg:max-w-xl"
            sizes="(max-width: 640px) 384px, (max-width: 768px) 512px, (max-width: 1024px) 512px, 576px"
          />
        </div>
        <ul
          class="md:justify-normal flex w-full flex-row justify-center gap-5 md:w-auto md:flex-col"
        >
          {
            socials.map((social) => (
              <li class="h-16 w-16 transition-all duration-300 hover:scale-125">
                <a href={social.link}>
                  <Image
                    src={social.icon}
                    alt={social.name}
                    width={80}
                    height={80}
                  />
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>
  <section>
    <div
      class="md:scroll-mt-18 mx-auto mt-3 max-w-screen-2xl scroll-mt-20 rounded-[67px] bg-surface-raised py-7 px-6"
      id="skills"
    >
      <div class="mx-auto max-w-7xl py-8">
        <h2 class="text-center text-3xl font-semibold text-text sm:text-left">
          My Skills
        </h2>
        <div
          class="grid grid-cols-1 place-content-center content-center gap-5 text-center uppercase sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5"
        >
          {
            sortedSkills.map((skill) => (
              <div class="mt-7 inline-block rounded-full border-4 border-solid border-accent bg-surface-raised px-5 py-3 text-2xl text-text transition-all duration-300 hover:scale-105 hover:border-accent-hover focus:outline-none focus:ring-2 focus:ring-focus focus:ring-offset-2 focus:ring-offset-surface">
                <p>{skill.data.text}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>
  <section>
    <div id="projects" class="mt-14 scroll-mt-28 px-6 text-center">
      <div class="mx-auto max-w-7xl">
        <h2 class="text-2xl md:text-4xl font-bold uppercase">Projects</h2>
        <p class="mt-4 font-light">
          Here&apos;s a small collection of some awesome websites and creations
          I&apos;ve made.
        </p>
        <div class="mt-10">
          {
            projects.map((project, i) => (
              <div class="mb-16 grid grid-cols-1 items-center gap-8 md:grid-cols-2">
                {i % 2 === 0 ? (
                  <>
                    <div class="image-wrapper">
                      <Image
                        class="w-full max-w-md md:max-w-full rounded-lg transition-transform duration-300 hover:scale-105"
                        src={project.data.image}
                        alt={project.data.title}
                        width={700}
                        height={500}
                        sizes="(max-width: 768px) 448px, 50vw"
                      />
                    </div>
                    <div class="text-center md:text-left">
                      <h3 class="mb-4 text-2xl font-semibold uppercase text-text">
                        {project.data.title}
                      </h3>
                      <p class="mb-6 text-text-muted">
                        {project.data.description}
                      </p>
                      <div class="flex justify-center gap-4 md:justify-start">
                        {project.data.buttons.map((button) => (
                          <button class="cursor-pointer rounded-full border-2 border-accent bg-transparent px-6 py-2 font-semibold text-accent transition-all duration-300 hover:bg-accent hover:text-surface focus:outline-none focus:ring-2 focus:ring-focus focus:ring-offset-2 focus:ring-offset-surface">
                            {button.text}
                          </button>
                        ))}
                      </div>
                    </div>
                  </>
                ) : (
                  <>
                    <div class="order-2 text-center md:order-1 md:text-right">
                      <h3 class="mb-4 text-2xl font-semibold uppercase text-text">
                        {project.data.title}
                      </h3>
                      <p class="mb-6 text-text-muted">
                        {project.data.description}
                      </p>
                      <div class="flex justify-center gap-4 md:justify-end">
                        {project.data.buttons.map((button) => (
                          <button class="cursor-pointer rounded-full border-2 border-accent bg-transparent px-6 py-2 font-semibold text-accent transition-all duration-300 hover:bg-accent hover:text-surface focus:outline-none focus:ring-2 focus:ring-focus focus:ring-offset-2 focus:ring-offset-surface">
                            {button.text}
                          </button>
                        ))}
                      </div>
                    </div>
                    <div class="image-wrapper order-1 md:order-2">
                      <Image
                        class="w-full rounded-lg transition-transform duration-300 hover:scale-105"
                        src={project.data.image}
                        alt={project.data.title}
                        width={700}
                        height={500}
                      />
                    </div>
                  </>
                )}
              </div>
            ))
          }
        </div>
      </div>
    </div>
    <!-- <MyProjects /> -->
  </section>
</HomeLayout>

