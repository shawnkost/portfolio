---
import '../styles/global.css';
const { title } = Astro.props;

const navLinks = [
  {
    slug: '/',
    title: 'Home',
  }
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="author" content="Shawn Kost" />
    <meta
      name="description"
      content="Software developer with a background in IT, web development, and teaching. Passionate about coding, mentoring, and building impactful apps."
    />
    <title>{title}</title>
  </head>
  <body class="min-h-screen">
    <header
      class="sticky top-0 z-20 flex w-full items-center bg-surface-raised/80 backdrop-blur-sm border-b border-border px-6 py-5"
    >
      <div class="mx-auto flex w-full max-w-7xl items-center justify-between">
        <p class="text-4xl font-bold text-accent drop-shadow-lg hover:text-accent-hover transition-colors duration-300" style="font-family: var(--font-heading)">S/K</p>
        <nav>
          <ul
            class="hidden list-none flex-row gap-10 text-lg font-semibold uppercase md:flex"
          >
            {
              navLinks.map((link) => (
                <li class="cursor-pointer transition-all duration-300 relative group"
                  ><a href=`${link.slug}`
                    class="relative z-10 px-3 py-2 rounded-lg outline-none focus:ring-2 focus:ring-focus focus:ring-offset-2 no-underline"
                  >
                    {link.title}
                  </a>
                  <div class="absolute inset-0 bg-accent/10 rounded-lg scale-0 group-hover:scale-100 transition-transform duration-300 -z-10"></div>
                </li>
              ))
            }
            <!-- <NavLinks links={navLinks} /> -->
          </ul>
        </nav>
        <!-- <div class="flex flex-1 items-center justify-end md:hidden">
          <Image
            src={toggle ? '/close.svg' : '/menu.svg'}
            alt="menu"
            height={28}
            width={28}
            class="h-[28px] w-[28px] cursor-pointer object-contain"
            onClick={() => setToggle(!toggle)}
          />
          <div
            class={`${
              !toggle ? 'hidden' : 'flex'
            } absolute top-20 right-0 z-10 mx-4 my-2 min-w-[140px] rounded-xl bg-secondary p-6`}
          >
            <ul class="flex list-none flex-col items-start justify-end gap-4">
              <NavLinks links={navLinks} />
            </ul>
          </div>
        </div> -->
      </div>
    </header>
    <main class="relative z-10">
      <slot />

      <!-- Subtle glow effects -->
      <div class="fixed top-0 left-0 w-96 h-96 bg-accent/5 rounded-full blur-3xl pointer-events-none -z-10"></div>
      <div class="fixed bottom-0 right-0 w-96 h-96 bg-focus/5 rounded-full blur-3xl pointer-events-none -z-10"></div>
    </main>
  </body>
</html>
